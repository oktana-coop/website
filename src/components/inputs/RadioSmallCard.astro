---
interface Props {
  value: string;
  label: string;
  group: string;
  checked?: boolean;
}

const { value, label, group, checked } = Astro.props;
---

<label
  aria-label={label}
  class="group relative flex items-center justify-center border border-gray-300 bg-white p-3 has-checked:border-black has-checked:bg-black has-focus-visible:outline-2 has-focus-visible:outline-offset-2 has-focus-visible:outline-black has-disabled:border-gray-400 has-disabled:bg-gray-200 has-disabled:opacity-25"
>
  <input
    type="radio"
    name={group}
    value={value}
    checked={checked}
    class="cursor-pointer absolute inset-0 appearance-none focus:outline-none disabled:cursor-not-allowed"
  />
  <span
    class="text-sm font-medium text-gray-900 capitalize group-has-checked:text-white"
    >{label}</span
  >
</label>
