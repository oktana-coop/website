---
import OutlineButton from '../../components/actions/buttons/OutlineButton.astro';
import SolidButton from '../../components/actions/buttons/SolidButton.astro';
import SectionHeading from '../../components/typography/SectionHeading.astro';
import RadioSmallCard from '../../components/inputs/RadioSmallCard.astro';

const textClasses =
  'text-sm/6 sm:text-base/7 md:text-lg/8 m-0 font-light text-left sm:text-justify';

const tiers = [
  { amount: 5, link: 'https://donate.stripe.com/00w9AS8dt8UC1ox31jfQI01' },
  { amount: 10, link: 'https://donate.stripe.com/5kQaEWfFV8UC7MV45nfQI02' },
  { amount: 25, link: 'https://donate.stripe.com/eVq4gyfFV3Ai8QZ6dvfQI03' },
];

const defaultTier = tiers[1];
---

<div id="support" class="flex flex-col gap-10">
  <div class="flex flex-col gap-4 md:gap-8">
    <SectionHeading text="Support our Work" />
    <div class="flex flex-col gap-4">
      <p class={textClasses}>
        We want to create tools that enhance our capacity for thinking and
        collaborating, tools that are oriented towards commons and treat
        knowledge as such. <a
          href="https://v2editor.com"
          class="text-rose-600 hover:text-rose-800"
          target="_blank"
          rel="noopener"><em>v2</em></a
        > is our first product manifesting this desire: it is a local-first editor
        with version control capabilities which gives you full agency over your data
        and is interoperable and composable with other tools. These properties, along
        with the fact that its source code is open, make <em>v2</em> resistant to
        becoming a commodity, which is something expected and desirable for us.
      </p>
      <p class={textClasses}>
        Alongside building tools that embody different values, we also want to
        analyze the society we are part of, with a view of changing it and
        weaving emancipatory alternatives. So part of our work is reflecting on
        how we work and produce, writing <a
          href="/blog"
          class="text-rose-600 hover:text-rose-800">essays</a
        > whose themes span political economy, technology and philosophy.
      </p>
      <p class={textClasses}>
        If you like our work and vision, please consider supporting us
        financially so that we can do more of this. We statutorily do not accept
        venture capital investment so that we stay independent and our resources
        are currently limited and based on personal savings from previous work
        we've undertaken. It would be amazing for us to reach a point where our
        work is community-funded as we plan to de-commodify knowledge production
        as much as possible and organize with like-minded people and
        initiatives.
      </p>
    </div>
    <div class="flex flex-col justify-center items-center gap-4">
      <h2
        class="text-lg md:text-xl text-black/85 dark:text-white/85 font-serif font-bold text-center"
      >
        Choose how you'd like to contribute
      </h2>
      <div class="flex flex-col justify-center gap-4 w-full sm:max-w-sm">
        <p class="text-xs/6 text-black/54 text-center">
          Steady funding keeps our work independent and sustainable.
        </p>

        <fieldset>
          <legend class="sr-only">Monthly support amount</legend>
          <div class="tier-picker grid grid-cols-3 gap-3">
            <!--
              The checked property just sets the default. The Tailwind has-checked:
              variant uses the CSS :checked pseudo-class under the hood,
              which tracks the DOM property, not the HTML attribute.
            -->
            {
              tiers.map((tier) => (
                <RadioSmallCard
                  value={tier.link}
                  label={`€${tier.amount}/month`}
                  group="support-tier"
                  checked={tier.link === defaultTier.link}
                />
              ))
            }
          </div>
        </fieldset>

        <div class="flex flex-col sm:flex-row sm:justify-between gap-4">
          <a
            id="recurring-support-link"
            href={defaultTier.link}
            target="_blank"
            rel="noopener"
            class="flex-auto"
          >
            <SolidButton
              icon="fa-stripe"
              text="Become a monthly supporter"
              size="lg"
              classes="w-full"
            />
          </a>
        </div>

        <div class="flex flex-col gap-4">
          <p class="text-xs/6 text-black/54 text-center">
            Other ways to contribute
          </p>
          <div class="flex flex-col gap-4">
            <a
              href="https://donate.stripe.com/6oU5kC51hfj03wF7hzfQI00"
              target="_blank"
              rel="noopener"
              class="flex-auto"
            >
              <OutlineButton
                icon="fa-stripe"
                text="One-time contribution"
                size="sm"
                classes="w-full"
              />
            </a>
            <a
              href="https://opencollective.com/oktana"
              target="_blank"
              rel="noopener"
              class="flex-auto"
            >
              <OutlineButton
                icon="open-collective"
                text="Open Collective"
                size="sm"
                classes="w-full"
              />
            </a>
            <a
              href="https://github.com/sponsors/oktana-coop"
              target="_blank"
              rel="noopener"
              class="flex-auto"
            >
              <OutlineButton
                icon="fa-github"
                text="GitHub Sponsors"
                size="sm"
                classes="w-full"
              />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const radios = document.querySelectorAll<HTMLInputElement>(
    '.tier-picker input[type="radio"]'
  );
  const recurringSupportLink = document.getElementById(
    'recurring-support-link'
  ) as HTMLAnchorElement | null;

  if (recurringSupportLink) {
    radios.forEach((radio) => {
      radio.addEventListener('change', () => {
        recurringSupportLink.href = radio.value;
      });
    });
  }
</script>
